# MEMOS_DRIVER=
# MEMOS_DSN=""
# Example PostgreSQL
MEMOS_DRIVER=postgres
MEMOS_DSN="postgres://user:password@db:5432/memos?sslmode=disable"
# Example SQLite
# MEMOS_DRIVER=sqlite
# MEMOS_DSN=/var/lib/memos/memos-gv-je.sqlite3
# Example MySQL
# MEMOS_DRIVER=mysql
# MEMOS_DSN="memos_user:password@tcp(db:3306)/memos?charset=utf8mb4&parseTime=True&loc=Local" 